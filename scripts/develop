#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

# Bootstrap dependencies when running develop directly.
python_executable="python3"
if [[ -x "${PWD}/.venv/bin/python" ]]; then
    python_executable="${PWD}/.venv/bin/python"
fi

if ! "${python_executable}" - <<'PY' >/dev/null 2>&1
import homeassistant  # noqa: F401
import hass_frontend  # noqa: F401
PY
then
    echo "Missing Python dependencies, running scripts/setup..."
    "${PWD}/scripts/setup"
fi

# Create config dir if not present
if [[ ! -d "${PWD}/config" ]]; then
    mkdir -p "${PWD}/config"
    .venv/bin/hass --config "${PWD}/config" --script ensure_config
fi

# Set the path to custom_components
## This let's us have the structure we want <root>/custom_components/flipped_energy
## while at the same time have Home Assistant configuration inside <root>/config
## without resulting to symlinks.
export PYTHONPATH="${PYTHONPATH}:${PWD}/custom_components"

# Start Home Assistant
.venv/bin/hass --config "${PWD}/config" --debug
